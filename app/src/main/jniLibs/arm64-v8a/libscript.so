#!/system/bin/sh
log -t pico.haxx.boot LIBSCRIPT.SO

export PACKAGE="pico.haxx"
export SERIAL="localhost:5555"
export LIBDIR=$(pm list packages -u -f $PACKAGE | grep -ioE "/.*/" | head -n 1)lib/arm64
export ADB=$LIBDIR/ladb.so
export SOCAT=$LIBDIR/socat

# Essential: rooted adbd will hog port 3057!
export ADB_SERVER_SOCKET=tcp:localhost:1234
export ANDROID_SERIAL="$SERIAL"

export HOME=/data/data/$PACKAGE
mkdir $HOME 2>/dev/null
mkdir $HOME/.android 2>/dev/null
cd $HOME

log -t pico.haxx.boot.LIBSCRIPT.SO "ADB:$ADB LIBDIR:$LIBDIR HOME:$HOME"

$ADB start-server

for x in {1..20}; do
    echo -e "[*] $ADB connect $SERIAL, try $x/20"
    $ADB connect $SERIAL && break
done

echo "[+] CONNECTED"

# Start socat: non-interactive oneshot mode
# Each connection reads stdin as a single command and exits
log -t pico.haxx.boot.LIBSCRIPT.SO "Starting socat on port 9000 serving adb shell (oneshot mode)"
$SOCAT TCP-LISTEN:9000,fork,reuseaddr EXEC:"$ADB shell sh -c \$(cat -)"
